# Prisma 直接读取现有的 SQLite 数据库（零数据迁移）。
# 路径相对于 prisma/ 目录（Prisma schema 所在处）。上面 schema.prisma 同级
# 的 prisma/,所以 ./ 是 prisma/ 自身,即 prisma/instance/database/db.db —— 不存在。
# 用 ../ 上一级到仓库根,再进 instance/database/db.db。生产更推荐绝对路径。
DATABASE_URL="file:../instance/database/db.db"

# 会话签名密钥。签 JWT 用，并且（向后兼容历史）仍是鱼干用户 API Key 字段
# 加密密钥的派生源 —— 见下方 FISH_ENCRYPTION_KEY 的说明。
SECRET_KEY="改成生产正在用的长随机串"

# 小鱼干用户 API Key 字段加密密钥。
#
# ⚠️ 首次部署既有数据库时：**留空**。
#
# 历史上该密钥**只**从 SECRET_KEY 派生（Fernet 套件）：
#   Fernet(base64.urlsafe_b64encode(sha256(SECRET_KEY)))
# 库里 fish_api_key_encrypted 的存量密文都是用 SECRET_KEY 加密的。
# 这里一旦填了非空值，Next 改用它派生密钥，存量密文立刻解不开
# （报 Invalid Token: HMAC），全站鱼干功能集体失效。
#
# 留空 = 回退 SECRET_KEY = 与历史一致 = 存量密文正常解开。
# 仅在全新部署、库里没有任何存量密文时，才考虑设独立密钥。
FISH_ENCRYPTION_KEY=""

# 游戏令牌签名密钥（供 /api/game/game_token 签发；未配置时回退 SECRET_KEY）
GAME_SECRET_KEY=""

# 魔杖 demo 实时 WebSocket 地址（默认 ws://localhost:3033，即原站硬编码地址）
NEXT_PUBLIC_WAND_WS_URL="ws://localhost:3033"

# 图床存储目录（缺省为 ./instance/images）
IMAGE_UPLOAD_FOLDER=""

# Cloudflare Turnstile（注册页人机验证；未启用则跳过）
TURNSTILE_AVAILABLE="False"
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_AVAILABLE="False"
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# 小鱼干账户微服务（账户服务已拆为独立 FastAPI 服务，独立仓库部署）
ACCOUNT_SERVICE_URL="http://localhost:8000"
ACCOUNT_SYSTEM_KEY=""
# ⚠️ 生产环境必填。不填则所有鱼干写路径（投喂/签到/注册/CLI）直接返回 503 ——
# 这是 fail-closed 的设计：宁可功能不可用，也不能出现「本地扣了鱼干、远端没记账」
# 的账目撕裂。
ACCOUNT_SERVICE_INTERNAL_TOKEN=""
ACCOUNT_SERVICE_TIMEOUT="5"

# ── 反向代理相关（套 nginx 时必配，否则会翻车）───────────────────────────────

# CSRF 白名单：允许发起写请求的站点来源，逗号分隔。
# 中间件拿浏览器的 Origin 跟它比对；对不上就当 CSRF 拒掉（403）。
# 套了 nginx 之后 Host 是 127.0.0.1:3000，与 Origin 对不上，所以必须显式配这个
# （或让 nginx 转发 X-Forwarded-Host，中间件会认）。
ALLOWED_ORIGINS="https://raricy.com"

# 会话 cookie 是否加 Secure 标记。留空则自动判断：
#   X-Forwarded-Proto（nginx 转发的）> NODE_ENV。
# 配错的典型症状：登录接口返回成功，但刷新后仍是未登录 —— 因为 cookie 被浏览器丢了。
# 走 HTTPS 就设 true；纯 HTTP 内网调试设 false。
COOKIE_SECURE=""
