# Prisma 直接读取 Flask 侧现有的 SQLite 数据库（零数据迁移）。
# 路径相对于 web-next/prisma/ 目录（Prisma schema 所在处）。
DATABASE_URL="file:../../instance/database/db.db"

# 会话签名密钥。迁移期务必与 Flask 的 SECRET_KEY 保持一致，
# 这样两套系统对密码哈希、加密字段（fish_api_key_encrypted）的处理才一致。
SECRET_KEY="换成与 Flask .env 相同的 SECRET_KEY"

# 小鱼干 API Key 字段加密密钥。
#
# ⚠️ 迁移既有数据库时：**留空**。
#
# Flask 侧没有这个变量 —— 它的 Fernet 密钥**只**从 SECRET_KEY 派生
# （见 app/clients/account_client.py:93）。库里 fish_api_key_encrypted 的存量密文
# 全部是用 SECRET_KEY 加密的。这里一旦填了值，Next 就改用它派生密钥，
# 存量密文立刻解不开（报 Invalid Token: HMAC），全站用户的鱼干功能集体失效。
#
# 留空 = 回退 SECRET_KEY = 与 Flask 一致 = 存量密文正常解开。
# 仅在全新部署、库里没有任何存量密文时，才考虑设独立密钥。
FISH_ENCRYPTION_KEY=""

# 游戏令牌签名密钥（对应 Flask 的 GAME_SECRET_KEY，供 /api/game/game_token 签发；未配置时回退 SECRET_KEY）
GAME_SECRET_KEY=""

# 魔杖 demo 实时 WebSocket 地址（默认 ws://localhost:3033，即原站硬编码地址）
NEXT_PUBLIC_WAND_WS_URL="ws://localhost:3033"

# 过渡期回源 Flask 的地址（头像、图床、以及尚未迁移的账户微服务调用）
FLASK_ORIGIN="http://127.0.0.1:5050"

# 图床存储目录（与 Flask 共用；缺省为 ../instance/images）
IMAGE_UPLOAD_FOLDER=""

# 过渡期回源 Flask 的公开地址（游戏 stub 的“去旧版”链接用）
NEXT_PUBLIC_FLASK_ORIGIN="https://raricy.com"

# Cloudflare Turnstile（注册页人机验证；未启用则跳过）
TURNSTILE_AVAILABLE="False"
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_AVAILABLE="False"
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# 小鱼干账户微服务（保持不变，Next 侧沿用同一后端）
ACCOUNT_SERVICE_URL="http://localhost:8000"
ACCOUNT_SYSTEM_KEY=""
# ⚠️ 生产环境必填。不填则所有鱼干写路径（投喂/签到/注册/CLI）直接返回 503 ——
# 这是 fail-closed 的设计（CLAUDE.md Phase 1.5）：宁可功能不可用，
# 也不能出现「本地扣了鱼干、远端没记账」的账目撕裂。
ACCOUNT_SERVICE_INTERNAL_TOKEN=""
ACCOUNT_SERVICE_TIMEOUT="5"

# ── 反向代理相关（套 nginx 时必配，否则会翻车）───────────────────────────────

# CSRF 白名单：允许发起写请求的站点来源，逗号分隔。
# 中间件拿浏览器的 Origin 跟它比对；对不上就当 CSRF 拒掉（403）。
# 套了 nginx 之后 Host 是 127.0.0.1:3000，与 Origin 对不上，所以必须显式配这个
# （或让 nginx 转发 X-Forwarded-Host，中间件会认）。
ALLOWED_ORIGINS="https://raricy.com"

# 会话 cookie 是否加 Secure 标记。留空则自动判断：
#   X-Forwarded-Proto（nginx 转发的）> NODE_ENV。
# 配错的典型症状：登录接口返回成功，但刷新后仍是未登录 —— 因为 cookie 被浏览器丢了。
# 走 HTTPS 就设 true；纯 HTTP 内网调试设 false。
COOKIE_SECURE=""
