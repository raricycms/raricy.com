# ─────────────────────────────────────────────────────────────────────────────
# 生产环境变量模板。复制为 .env.production 并填入真实值。
# ⚠️ 本文件不含任何真实密钥；.env* 已被 .gitignore 排除。
# ─────────────────────────────────────────────────────────────────────────────

# 数据库：指向已【规整为 ISO】的生产 SQLite（见迁移文档 03 §3/§6）。
# 切换前务必：备份 → 规整(npm run db:normalize --in-place) → 确认 Flask 已停写。
# connection_limit=1 + socket_timeout=30：SQLite 是单写库，序列化访问让并发写【排队】
# 而不是抛 Socket timeout(500)。已实测：60 并发读写 → 60×200、0 错误。
# 真正的高并发写扩展仍建议迁 Postgres（届时去掉这两个参数）。
DATABASE_URL="file:/绝对路径/instance/database/db.db?connection_limit=1&socket_timeout=30"

# ⚠️⚠️ 会话与加密密钥 —— 必须与 Flask 生产环境【完全一致】 ⚠️⚠️
#   1) SECRET_KEY：会话签名。与 Flask 不一致 → 无法平滑，且下方加密回退失效。
#   2) FISH_ENCRYPTION_KEY：解密 users.fish_api_key_encrypted 的密钥。
#      —— 实测：若此值不对，465 个用户的账户 Key 全部解不开，小鱼干经济全线 503。
#      Flask 逻辑：优先用 FISH_ENCRYPTION_KEY，未配置才回退 SECRET_KEY。
#      **必须照搬 Flask 生产 .env 里实际用于加密这批数据的那个密钥**，否则经济系统瘫痪。
SECRET_KEY="<照搬 Flask 生产 SECRET_KEY>"
FISH_ENCRYPTION_KEY="<照搬 Flask 生产 FISH_ENCRYPTION_KEY；若历史数据用 SECRET_KEY 加密则留空>"

# 真实资源目录（与 Flask 共用同一份磁盘文件）
IMAGE_UPLOAD_FOLDER="/绝对路径/instance/images"
AVATARS_DIR="/绝对路径/instance/avatars"
STORIES_DIR="/绝对路径/instance/stories"

# 小鱼干账户微服务（FastAPI）—— 必须可达，否则投喂/签到发鱼会 fail-closed(503)
ACCOUNT_SERVICE_URL="http://127.0.0.1:8000"
ACCOUNT_SYSTEM_KEY="<系统账户 API Key>"
ACCOUNT_SERVICE_INTERNAL_TOKEN="<服务间共享令牌>"
ACCOUNT_SERVICE_TIMEOUT="5"

# CSRF：若前端与后端不同域，在此列出可信来源（逗号分隔）
ALLOWED_ORIGINS=""

# Cloudflare Turnstile（注册页人机验证）
TURNSTILE_AVAILABLE="True"
TURNSTILE_SECRET_KEY="<Turnstile secret>"
NEXT_PUBLIC_TURNSTILE_AVAILABLE="True"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="<Turnstile site key>"

NODE_ENV="production"
