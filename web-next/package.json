{
  "name": "raricy-next",
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "description": "Next.js rebuild of raricy.com (聪明山) — reads the existing Flask SQLite database via Prisma.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:normalize": "node scripts/normalize-datetimes.mjs --source ../instance/database/db.db --dest prisma/dev.db",
    "diagnose": "tsx scripts/diagnose-deploy.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:perms": "node scripts/check-permissions.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:compensate-fortunes": "node scripts/compensate-unclaimed-fortunes.mjs",
    "cli": "tsx scripts/cli.mjs",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "playwright test --ui",
    "verify:account": "tsx scripts/verify-account-integration.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "dompurify": "^3.4.12",
    "fernet": "^0.3.3",
    "highlight.js": "^11.11.1",
    "jose": "^5.9.6",
    "marked": "^18.0.6",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "prisma": "^6.2.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
